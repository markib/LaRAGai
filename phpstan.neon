parameters:
    paths:
        - app
        - config
        - database
        - routes

    level: 6
    treatPhpDocTypesAsCertain: false
    
    # This prevents PHPStan from crashing when an ignored error disappears
    reportUnmatchedIgnoredErrors: false

    ignoreErrors:
        - '#Call to an undefined static method Cloudstudio\\Ollama\\Facades\\Ollama::model\(\)#'
        # FIX: Ignores phantom "undefined method" errors on Route/Request/Guard facades
        - '#Call to an undefined method Illuminate\\Routing\\Route::name\(\)#'
        - '#Call to an undefined method Illuminate\\Routing\\Route::middleware\(\)#'
        - '#Call to an undefined method Illuminate\\Foundation\\Auth\\EmailVerificationRequest::user\(\)#'
        - '#Call to an undefined method Illuminate\\Contracts\\Auth\\Guard::logout\(\)#'
        - '#Call to an undefined method Illuminate\\Http\\Request::ip\(\)#'
        - '#expectsJson#'

    scanFiles:
        - _ide_helper.php
        - _ide_helper_models.php    

    tmpDir: storage/phpstan

    # FORCE COUPLING FIX: This stops generic model/factory conversion friction
    universalObjectCratesClasses:
        - Illuminate\Database\Eloquent\Relations\Pivot
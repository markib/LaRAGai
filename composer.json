{
  "name": "laravel/laragai",
  "description": "Laravel RAG project with React TypeScript frontend and Ollama local LLM.",
  "type": "project",
  "require": {
    "php": "^8.1.0",
    "laravel/framework": "^10.0",
    "guzzlehttp/guzzle": "^7.0",
    "cloudstudio/ollama-laravel": "^1.0",
    "predis/predis": "^3.4",
    "laravel/tinker": "^3.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0",
    "pestphp/pest": "^2.36",
    "pestphp/pest-plugin-laravel": "^2.4",
    "mockery/mockery": "^1.6",
    "fakerphp/faker": "^1.24"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    },
    "classmap": [
      "database/factories"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "serve": "php artisan serve",
    "test": "vendor/bin/pest",
    "test:php": "vendor/bin/pest",
    "test:php:watch": "vendor/bin/pest --watch"
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  }
}

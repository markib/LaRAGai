{
  "name": "laravel/laragai",
  "description": "Laravel RAG project with React TypeScript frontend and Ollama local LLM.",
  "type": "project",
  "require": {
    "php": "^8.1.0",
    "laravel/framework": "^10.0",
    "guzzlehttp/guzzle": "^7.0",
    "cloudstudio/ollama-laravel": "^1.0",
    "predis/predis": "^3.4",
    "laravel/tinker": "^3.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "serve": "php artisan serve"
  }
}

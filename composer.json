{
    "name": "laravel/laragai",
    "description": "Laravel RAG project with React TypeScript frontend and Ollama local LLM.",
    "type": "project",
    "require": {
        "php": "^8.3",
        "cloudstudio/ollama-laravel": "^1.0",
        "guzzlehttp/guzzle": "^7.9",
        "laravel/framework": "^12.0",
        "laravel/reverb": "^1.10",
        "laravel/tinker": "^3.0",
        "livewire/livewire": "^3.6.4",
        "livewire/volt": "^1.7.0",
        "predis/predis": "^3.4",
        "smalot/pdfparser": "^2.12"
    },
    "require-dev": {
        "barryvdh/laravel-ide-helper": "^3.7",
        "fakerphp/faker": "^1.24",
        "larastan/larastan": "^3.10",
        "laravel/breeze": "^2.4",
        "laravel/pint": "^1.29",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "pestphp/pest": "^3.8",
        "pestphp/pest-plugin-laravel": "^3.2"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "serve": "php artisan serve",
        "test": "vendor/bin/pest"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        },
        "abandoned": "ignore"
    }
}

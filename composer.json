{
    "name": "laravel/laragai",
    "description": "Laravel RAG project with React TypeScript frontend and Ollama local LLM.",
    "type": "project",
    "require": {
        "php": "^8.3",
        "cloudstudio/ollama-laravel": "^1.0",
        "codewithkyrian/chromadb-php": "*",
        "guzzlehttp/guzzle": "^7.9",
        "laravel/framework": "^12.0",
        "laravel/tinker": "^3.0",
        "livewire/livewire": "^4.0",
        "phpoffice/phpword": "^1.3",
        "predis/predis": "^3.4",
        "smalot/pdfparser": "^2.12"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5",
        "pestphp/pest": "^3.8",
        "pestphp/pest-plugin-laravel": "^3.2",
        "nunomaduro/collision": "^8.6",
        "fakerphp/faker": "^1.24",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "serve": "php artisan serve",
        "test": "vendor/bin/pest"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    }
}
